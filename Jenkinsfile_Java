def extractServiceName(String gitUrl) {
    return gitUrl.tokenize('/')[-1].replace('.git', '').toLowerCase()
}

node(params.AGENT_LABELS) {

    properties([
        parameters([
            choice(
                name: 'GIT_REPOSITORY',
                choices: [
                    'https://github.com/your-org/service-a.git',
                    'https://github.com/your-org/service-b.git',
                    'https://github.com/your-org/service-c.git',
                    'https://gitlab.com/nab3735908/demo-project/java-service.git'
                ],
                description: 'Select the Git repository to build'
            ),
            activeChoice(
                name: 'AGENT_LABELS',
                description: 'Select one or more agent labels',
                filterable: false,
                choiceType: 'PT_CHECKBOX',
                script: [
                    $class: 'GroovyScript',
                    fallbackScript: [
                        classpath: [],
                        sandbox: true,
                        script: 'return ["General"]'
                    ],
                    script: [
                        classpath: [],
                        sandbox: true,
                        script: 'return ["General:selected", "Java", "Docker", "Linux"]'
                    ]
                ]
            ),
            choice(
                name: 'BRANCH',
                choices: ['dev', 'staging', 'production'],
                description: 'Select branch to build'
            ),
            string(
                name: 'BRANCH_OVERRIDE',
                defaultValue: '',
                description: 'Override branch (leave empty to use selected BRANCH above)'
            ),
            choice(
                name: 'DOCKERFILE_FOLDER',
                choices: ['java-service', 'jenkins-inbound-agent'],
                description: 'Select folder containing the Dockerfile to use for build'
            ),
            booleanParam(
                name: 'SKIP_UNIT_TESTS',
                defaultValue: false,
                description: 'Skip unit tests during build'
            )
        ])
    ])

    def dockerhubUsername   = 'khangtictoc'
    def dockerfileRepoUrl   = 'https://github.com/khangtictoc/dockerfile-common.git'
    def serviceName         = extractServiceName(params.GIT_REPOSITORY)
    def imageName           = "${dockerhubUsername}/${serviceName}"
    def imageTag            = "${params.BRANCH}-${BUILD_NUMBER}"
    def targetBranch        = params.BRANCH_OVERRIDE?.trim() ? params.BRANCH_OVERRIDE.trim() : params.BRANCH
    def gitCommit           = ''
    def fullImage           = "${imageName}:${imageTag}"

    // Environment Variables
    def AGENT_POD_NAME      = env.AGENT_POD_NAME
    def AGENT_POD_NAMESPACE = env.AGENT_POD_NAMESPACE
    def WORKSPACE           = env.WORKSPACE
    def BUILD_NUMBER         = env.BUILD_NUMBER

    stage('Checkout - Application Source') {
        sh """
            echo "--- Cloning Application Repository ---"
            echo "    Repo: ${params.GIT_REPOSITORY}"
            echo "    Branch: ${targetBranch}"
        """
        
        sh """
            rm -rf app-source
            git clone --branch ${targetBranch} --single-branch ${params.GIT_REPOSITORY} app-source
        """
        dir('app-source') {
            gitCommit = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
        }
    }

    stage('Checkout - Dockerfile') {
        sh """
            echo "--- Cloning Dockerfile Repository ---"
            echo "    Repo: ${dockerfileRepoUrl}"
            echo "    Folder: ${params.DOCKERFILE_FOLDER}"
            echo "    Image will be tagged: ${fullImage}"
        """

        sh """
            rm -rf dockerfile-common
            git clone --single-branch ${dockerfileRepoUrl} dockerfile-common
            cp dockerfile-common/${params.DOCKERFILE_FOLDER}/Dockerfile app-source/Dockerfile
        """
    }

    stage('Unit Tests') {
        if (!params.SKIP_UNIT_TESTS) {
            sh """
                echo "--- Kaniko - Unit Tests ---"
                echo
                echo

                kubectl exec ${AGENT_POD_NAME} \
                        -n ${AGENT_POD_NAMESPACE} \
                        -c kaniko \
                        -- /kaniko/executor \
                            --context="dir://${WORKSPACE}/app-source" \
                            --dockerfile="${WORKSPACE}/app-source/Dockerfile" \
                            --target=builder \
                            --build-arg RUN_TESTS=true \
                            --no-push
            """
        } else {
            echo 'Unit tests skipped.'
        }
    }

    stage('Build & Push Docker Image') {
        echo "Building and pushing: ${fullImage}"
        sh """
            echo "--- Kaniko - Build & Push ---"
            echo
            echo

            kubectl exec ${AGENT_POD_NAME} \
                -n ${AGENT_POD_NAMESPACE} \
                -c kaniko \
                -- /kaniko/executor \
                    --context="dir://${WORKSPACE}/app-source" \
                    --dockerfile="${WORKSPACE}/app-source/Dockerfile" \
                    --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                    --build-arg GIT_COMMIT=${gitCommit} \
                    --destination=${fullImage} \
                    --destination=${imageName}:latest
        """
    }

    echo """
    ✅ Build SUCCESS
    Image      : ${fullImage}
    Repo       : ${params.GIT_REPOSITORY}
    Branch     : ${targetBranch}
    Dockerfile : dockerfile-common/${params.DOCKERFILE_FOLDER}/Dockerfile
    Tests      : ${params.SKIP_UNIT_TESTS ? 'Skipped' : 'Passed'}
    """
}